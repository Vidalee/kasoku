# Production environment — copy to .env on your VPS and fill in values
# DO NOT commit .env to git

# ── SQLite ─────────────────────────────────────────────────────────────────────
# Absolute path on the VPS — keep outside the app directory so deploys don't wipe it
DATABASE_PATH=/var/lib/kasoku/kasoku.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: bun -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('yourpassword', 12))"
AUTH_PASSWORD_HASH=<bcrypt-hash>

# Generate: openssl rand -base64 32
JWT_SECRET=<random-32-char-secret>
